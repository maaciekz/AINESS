        "                     fontsize=11, color=color)\n",
        "        ax.set_xticks([]); ax.set_yticks([])\n",
        "    plt.suptitle(\"Interpolacja AI → Real (10 punktów)\", fontsize=14)\n",
        "    plt.tight_layout()\n",
        "    plt.savefig(save_path, dpi=100, bbox_inches='tight')\n",
        "    plt.close()\n",
        "\n",
        "def save_difference_panel(img_alpha_0, img_alpha_1, save_path, amplify=4):\n",
        "    \"\"\"Zapisz panel z różnicą oryginału (po round-trip) i zedytowanego.\"\"\"\n",
        "    diff_raw = np.abs(img_alpha_0.astype(np.int16) - img_alpha_1.astype(np.int16))\n",
        "    diff_amp = np.clip(diff_raw * amplify, 0, 255).astype(np.uint8)\n",
