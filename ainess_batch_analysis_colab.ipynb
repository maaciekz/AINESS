        "def compute_xai(img_clf):\n",
        "    \"\"\"Liczy 4 mapy XAI dla obrazu 224×224.\"\"\"\n",
        "    X = img_clf[np.newaxis].astype(np.float32)\n",
        "    cam = gradcam(score, X, penultimate_layer=PENULTIMATE_LAYER_NAME)[0]\n",
        "    cam_pp = gradcam_pp(score, X, penultimate_layer=PENULTIMATE_LAYER_NAME)[0]\n",
        "    sal = saliency(score, X)[0]\n",
        "    smooth = saliency(score, X, smooth_samples=20, smooth_noise=0.20)[0]\n",
        "    return {'gradcam': cam, 'gradcam_pp': cam_pp, 'saliency': sal, 'smoothgrad': smooth}\n",
        "\n",
        "def save_xai_panel(img_clf, prob, heatmaps, save_path):\n",
        "    \"\"\"Zapisz panel 2×4: oryginał + 4 mapy XAI overlay + raw.\"\"\"\n",
        "    img_uint8 = img_clf.astype(np.uint8)\n",
        "    label = \"AI-Generated\" if prob > 0.5 else \"Real\"\n",
        "    confidence = max(prob, 1 - prob) * 100\n",
        "    color = '#e74c3c' if prob > 0.5 else '#2ecc71'\n",
        "\n",
        "    fig, axes = plt.subplots(2, 4, figsize=(20, 10))\n",
        "\n",
        "    # Rząd 1: Grad-CAM family\n",
        "    axes[0, 0].imshow(img_uint8)\n",
        "    axes[0, 0].set_title(f\"{label} ({confidence:.1f}%)\\nP(AI) = {prob:.4f}\",\n",
        "                          fontsize=11, fontweight='bold', color=color)\n",
        "    axes[0, 1].imshow(overlay_heatmap(img_clf, heatmaps['gradcam'], 'jet', 0.5))\n",
        "    axes[0, 1].set_title(\"Grad-CAM overlay\", fontsize=11)\n",
        "    axes[0, 2].imshow(overlay_heatmap(img_clf, heatmaps['gradcam_pp'], 'jet', 0.5))\n",
        "    axes[0, 2].set_title(\"Grad-CAM++ overlay\", fontsize=11)\n",
        "    axes[0, 3].imshow(heatmaps['gradcam'], cmap='jet')\n",
        "    axes[0, 3].set_title(\"Grad-CAM (raw heatmap)\", fontsize=11)\n",
        "\n",
        "    # Rząd 2: Saliency family\n",
        "    axes[1, 0].imshow(img_uint8)\n",
        "    axes[1, 0].set_title(\"Oryginał\", fontsize=11)\n",
        "    axes[1, 1].imshow(heatmaps['saliency'], cmap='hot')\n",
        "    axes[1, 1].set_title(\"Vanilla Saliency\", fontsize=11)\n",
        "    axes[1, 2].imshow(heatmaps['smoothgrad'], cmap='hot')\n",
        "    axes[1, 2].set_title(\"SmoothGrad (N=20)\", fontsize=11)\n",
        "    axes[1, 3].imshow(overlay_heatmap(img_clf, heatmaps['smoothgrad'], 'hot', 0.6))\n",
        "    axes[1, 3].set_title(\"SmoothGrad overlay\", fontsize=11)\n",
        "\n",
        "    for ax in axes.flatten():\n",
        "        ax.set_xticks([]); ax.set_yticks([])\n",
        "\n",
        "    plt.suptitle(f\"Analiza XAI | P(AI)={prob:.4f}\", fontsize=14, fontweight='bold', color=color)\n",
        "    plt.tight_layout()\n",
        "    plt.savefig(save_path, dpi=100, bbox_inches='tight')\n",
        "    plt.close()\n",
        "\n",
        "def save_interpolation_grid(interpolations, save_path):\n",
        "    \"\"\"Zapisz grid 2×5 z 10 obrazów interpolacji.\"\"\"\n",
        "    fig, axes = plt.subplots(2, 5, figsize=(20, 8))\n",
        "    for i, r in enumerate(interpolations):\n",
        "        ax = axes.flatten()[i]\n",
        "        ax.imshow(r['image'])\n",
        "        color = 'green' if r['prob_ai'] < 0.5 else 'red'\n",
