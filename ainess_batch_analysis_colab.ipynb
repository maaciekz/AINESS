      "source": [
        "def optimize_latent(z_0, n_steps=N_GD_STEPS, lr=GD_LR, lambda_reg=GD_LAMBDA_REG,\n",
        "                    target_prob=TARGET_PROB_REAL):\n",
        "    \"\"\"Gradient descent: znajdź z_final minimalizujące prob_AI.\"\"\"\n",
        "    z = z_0.clone().detach().requires_grad_(True)\n",
        "    optimizer = torch.optim.Adam([z], lr=lr)\n",
        "    history = {'prob_ai': []}\n",
        "\n",
        "    for step in range(n_steps):\n",
        "        optimizer.zero_grad()\n",
        "        prob_ai = pipeline(z)\n",
        "        loss = prob_ai.mean() + lambda_reg * ((z - z_0)**2).sum()\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "        prob_val = prob_ai.detach().cpu().item()\n",
        "        history['prob_ai'].append(prob_val)\n",
        "        if prob_val < target_prob:\n",
        "            break\n",
        "\n",
        "    return z.detach(), history\n",
        "\n",
        "def generate_interpolation(img_np):\n",
        "    \"\"\"Pełen pipeline: encode → optimize → interpolate → decode.\n",
        "\n",
        "    Returns: list of 10 dicts {alpha, prob_ai, image}, plus initial/final prob.\n",
        "    \"\"\"\n",
        "    # Encode\n",
        "    z_0 = encode_to_latent(img_np)\n",
        "    initial_prob = classify_latent(z_0)\n",
        "\n",
        "    # Optimize\n",
        "    z_final, history = optimize_latent(z_0)\n",
        "    final_prob = history['prob_ai'][-1]\n",
        "\n",
        "    # Interpolate\n",
        "    alphas = np.linspace(0, 1, N_ALPHAS)\n",
        "    results = []\n",
        "    for alpha in alphas:\n",
        "        z_alpha = (1 - float(alpha)) * z_0 + float(alpha) * z_final\n",
        "        img_alpha = decode_to_img(z_alpha)\n",
        "        prob_alpha = classify_latent(z_alpha)\n",
        "        results.append({'alpha': float(alpha), 'prob_ai': float(prob_alpha), 'image': img_alpha})\n",
        "\n",
        "    return {\n",
        "        'interpolations': results,\n",
        "        'initial_prob': initial_prob,\n",
        "        'final_prob': final_prob,\n",
        "        'n_steps_used': len(history['prob_ai']),\n",
        "        'history': history['prob_ai'],\n",
        "    }\n",
        "\n",
        "print(\"✅ Generation functions gotowe\")\n"
      ]
    },
