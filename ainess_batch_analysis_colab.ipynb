        "def diagnose_convergence(n_steps_used, final_prob, ssim_value):\n",
        "    \"\"\"Klasyfikuje wzorzec konwergencji gradient descent.\n",
        "\n",
        "    Returns: dict z 'category' i 'recommendation'.\n",
        "    \"\"\"\n",
        "    if n_steps_used < 20 and final_prob < 0.05 and ssim_value > 0.92:\n",
        "        return {\n",
        "            'category': 'early_convergence',\n",
        "            'description': 'Optymalizacja zakończyła się szybko z minimalnymi zmianami',\n",
        "            'recommendation': 'Obniż GD_LAMBDA_REG (np. ×0.1) i TARGET_PROB_REAL (np. ×0.1) dla silniejszej edycji',\n",
        "        }\n",
        "    elif n_steps_used >= N_GD_STEPS - 5 and final_prob > 0.3:\n",
        "        return {\n",
        "            'category': 'no_convergence',\n",
        "            'description': 'Optymalizacja nie zdążyła przepchnąć obrazu do Real w limicie kroków',\n",
        "            'recommendation': 'Zwiększ N_GD_STEPS (np. ×2) lub GD_LR (np. ×2)',\n",
        "        }\n",
        "    elif final_prob > 0.5:\n",
        "        return {\n",
        "            'category': 'failed_flip',\n",
        "            'description': 'Klasyfikator nadal uważa obraz za AI po pełnej optymalizacji',\n",
        "            'recommendation': 'Trudny obraz — być może DALL-E-typ lub silne sygnatury AI. Sprawdź per-generator',\n",
        "        }\n",
        "    elif ssim_value < 0.6:\n",
        "        return {\n",
        "            'category': 'over_edit',\n",
        "            'description': 'Obraz znacznie się zmienił — niska podobność do oryginału',\n",
        "            'recommendation': 'Zwiększ GD_LAMBDA_REG (np. ×5) lub zwiększ TARGET_PROB_REAL',\n",
        "        }\n",
        "    else:\n",
        "        return {\n",
        "            'category': 'normal',\n",
        "            'description': 'Standardowa konwergencja',\n",
        "            'recommendation': 'Parametry odpowiednie',\n",
        "        }\n",
        "\n",
        "def process_image(image_path, force=False):\n",
        "    \"\"\"Główna funkcja: przetwarza jeden obraz, zapisuje pełen pakiet wyników.\n",
        "\n",
        "    Returns: dict ze statystykami lub None jeśli pominięto.\n",
        "    \"\"\"\n",
        "    image_path = Path(image_path)\n",
        "    name = image_path.stem  # nazwa bez rozszerzenia\n",
        "    out_dir = OUTPUT_DIR / name\n",
        "\n",
        "    # Cache check — jeśli folder ma metadata.json, pomijamy\n",
        "    if not force and (out_dir / \"metadata.json\").exists():\n",
        "        return {'name': name, 'status': 'cached', 'skipped': True}\n",
        "\n",
        "    out_dir.mkdir(parents=True, exist_ok=True)\n",
        "    t_start = time.time()\n",
        "\n",
        "    # ── Załaduj obraz ──\n",
        "    img_pil_orig = Image.open(image_path).convert('RGB')\n",
        "    img_np_768 = preprocess_image(img_pil_orig, target_size=EDIT_RES)\n",
        "    img_clf = img_for_classifier(img_np_768)  # 224×224\n",
        "\n",
        "    # ── Pre-compute prob_AI dla oryginału (potrzebne do nazwy pliku) ──\n",
        "    prob = predict_tf(img_clf)\n",
        "    prob_tag = f\"{int(round(prob * 1000)):04d}\"  # 0.987 → '0987'\n",
        "\n",
        "    # ── (a) Zapisz oryginał z prob_AI w nazwie ──\n",
        "    Image.fromarray(img_np_768).save(out_dir / f\"00_original_aiprob_{prob_tag}.png\")\n",
        "\n",
        "    # ── (b) XAI ──\n",
        "    heatmaps = compute_xai(img_clf)\n",
        "    save_xai_panel(img_clf, prob, heatmaps, out_dir / \"01_xai_panel.png\")\n",
        "\n",
        "    # Zapisz też raw heatmaps jako PNG (do późniejszej analizy)\n",
        "    for name_hm, hm in heatmaps.items():\n",
        "        # Normalizuj do [0, 255]\n",
        "        hm_norm = (hm - hm.min()) / (hm.max() - hm.min() + 1e-8)\n",
        "        hm_uint = (hm_norm * 255).astype(np.uint8)\n",
        "        Image.fromarray(hm_uint).save(out_dir / f\"02_xai_{name_hm}.png\")\n",
        "\n",
        "    # ── (c) Interpolacja ──\n",
        "    gen = generate_interpolation(img_np_768)\n",
        "    save_interpolation_grid(gen['interpolations'], out_dir / \"03_interpolation_grid.png\")\n",
        "\n",
        "    # Zapisz pojedyncze klatki interpolacji z prob_AI w nazwie\n",
        "    for r in gen['interpolations']:\n",
        "        alpha_prob_tag = f\"{int(round(r['prob_ai'] * 1000)):04d}\"\n",
        "        Image.fromarray(r['image']).save(\n",
        "            out_dir / f\"alpha_{r['alpha']:.2f}_aiprob_{alpha_prob_tag}.png\"\n",
        "        )\n",
        "\n",
        "    # ── (d) Różnica ──\n",
        "    img_alpha_0 = gen['interpolations'][0]['image']\n",
        "    img_alpha_1 = gen['interpolations'][-1]['image']\n",
        "    ssim_value = save_difference_panel(img_alpha_0, img_alpha_1, out_dir / \"04_difference_x4.png\")\n",
        "\n",
        "    # ── Metadata ──\n",
        "    elapsed = time.time() - t_start\n",
        "    metadata = {\n",
        "        'image_name': name,\n",
        "        'source_path': str(image_path),\n",
        "        'processed_at': datetime.now().isoformat(),\n",
        "        'processing_time_seconds': elapsed,\n",
        "        'parameters': {\n",
        "            'edit_resolution': EDIT_RES,\n",
        "            'clf_resolution': CLF_RES,\n",
        "            'n_alphas': N_ALPHAS,\n",
        "            'gd_steps_max': N_GD_STEPS,\n",
        "            'gd_lr': GD_LR,\n",
        "            'gd_lambda_reg': GD_LAMBDA_REG,\n",
        "            'target_prob_real': TARGET_PROB_REAL,\n",
        "        },\n",
        "        'results': {\n",
        "            'prob_ai_tf_classifier': float(prob),\n",
        "            'prob_ai_at_alpha_0': gen['interpolations'][0]['prob_ai'],\n",
        "            'prob_ai_at_alpha_1': gen['interpolations'][-1]['prob_ai'],\n",
        "            'initial_prob_in_gd': gen['initial_prob'],\n",
        "            'final_prob_in_gd': gen['final_prob'],\n",
        "            'gd_steps_used': gen['n_steps_used'],\n",
        "            'gd_history': gen['history'],\n",
        "            'ssim_alpha_0_vs_alpha_1': float(ssim_value),\n",
        "            'convergence_diagnosis': diagnose_convergence(\n",
        "                gen['n_steps_used'], gen['final_prob'], float(ssim_value)\n",
        "            ),\n",
        "            'alphas': [r['alpha'] for r in gen['interpolations']],\n",
        "            'prob_ais_per_alpha': [r['prob_ai'] for r in gen['interpolations']],\n",
        "        },\n",
        "    }\n",
        "    with open(out_dir / \"metadata.json\", 'w', encoding='utf-8') as f:\n",
        "        json.dump(metadata, f, indent=2, ensure_ascii=False)\n",
        "\n",
        "    # GPU cleanup\n",
        "    if device.type == 'cuda':\n",
        "        torch.cuda.empty_cache()\n",
        "\n",
        "    return {\n",
        "        'name': name,\n",
        "        'status': 'ok',\n",
        "        'time': elapsed,\n",
        "        'prob_orig': float(prob),\n",
        "        'prob_final': gen['final_prob'],\n",
        "        'gd_steps': gen['n_steps_used'],\n",
        "        'ssim': float(ssim_value),\n",
        "    }\n",
        "\n",
        "print(\"✅ process_image() gotowy\")\n"
      ]
    },
