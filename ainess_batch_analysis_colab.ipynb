      "source": [
        "# Inicjalizacja XAI tools\n",
        "score = BinaryScore(1.0)\n",
        "replace_linear = ReplaceToLinear()\n",
        "\n",
        "gradcam = Gradcam(flat_model, model_modifier=replace_linear, clone=True)\n",
        "gradcam_pp = GradcamPlusPlus(flat_model, model_modifier=replace_linear, clone=True)\n",
        "saliency = Saliency(flat_model, model_modifier=replace_linear, clone=True)\n",
        "\n",
        "print(\"✅ XAI tools ready: Grad-CAM, Grad-CAM++, Saliency\")\n"
      ]
    },
