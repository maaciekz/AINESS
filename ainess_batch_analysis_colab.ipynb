        "## 4. Pipeline end-to-end + funkcje pomocnicze\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 11,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "xu9yWkCczs1B",
        "outputId": "0ab245eb-c4b6-4aa1-d557-61a3ce58bbc2"
      },
      "outputs": [
        {
          "output_type": "stream",
