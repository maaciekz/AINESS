      "source": [
        "class EndToEndPipeline(nn.Module):\n",
        "    \"\"\"SD-VAE decoder + resize + classifier — jeden różniczkowalny graf.\"\"\"\n",
        "    def __init__(self, vae, classifier, input_format='NHWC'):\n",
        "        super().__init__()\n",
        "        self.vae = vae\n",
        "        self.classifier = classifier\n",
        "        self.input_format = input_format\n",
        "\n",
        "    def decode(self, z):\n",
        "        return self.vae.decode(z / SCALE_FACTOR).sample\n",
        "\n",
        "    def forward(self, z):\n",
        "        img = self.decode(z)\n",
        "        img_resized = F.interpolate(img, size=CLF_RES, mode='bilinear', align_corners=False)\n",
        "        img_0to255 = (img_resized + 1.0) * 127.5\n",
        "        if self.input_format == 'NHWC':\n",
        "            img_0to255 = img_0to255.permute(0, 2, 3, 1)\n",
        "        prob_ai = self.classifier(img_0to255)\n",
        "        if prob_ai.dim() > 1:\n",
        "            prob_ai = prob_ai.squeeze(-1)\n",
        "        return prob_ai\n",
        "\n",
        "pipeline = EndToEndPipeline(vae, pt_classifier, input_format=pt_input_format).to(device).eval()\n",
        "print(\"✅ Pipeline gotowy\")\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 12,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "a1ndaTAezs1B",
        "outputId": "36143361-5b40-4362-90a0-f0c2086de33b"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ Helpers gotowe\n"
          ]
        }
      ],
      "source": [
        "# Helpers do konwersji obraz ↔ tensor\n",
        "def preprocess_image(img_pil, target_size=EDIT_RES):\n",
        "    \"\"\"PIL Image → numpy uint8 [size, size, 3], z center crop.\"\"\"\n",
        "    img_pil = img_pil.convert('RGB')\n",
        "    w, h = img_pil.size\n",
        "    if w != h:\n",
        "        s = min(w, h)\n",
        "        left = (w - s) // 2\n",
        "        top = (h - s) // 2\n",
        "        img_pil = img_pil.crop((left, top, left+s, top+s))\n",
        "    img_pil = img_pil.resize((target_size, target_size), Image.LANCZOS)\n",
        "    return np.array(img_pil)\n",
        "\n",
        "def img_to_torch(img_np):\n",
        "    t = torch.from_numpy(img_np.astype(np.float32)).permute(2, 0, 1).unsqueeze(0)\n",
        "    return (t / 127.5 - 1.0).to(device)\n",
        "\n",
        "def torch_to_img(tensor):\n",
        "    t = tensor.detach().cpu().squeeze(0)\n",
        "    t = (t.clamp(-1, 1) + 1) * 127.5\n",
        "    return t.permute(1, 2, 0).numpy().astype(np.uint8)\n",
        "\n",
        "@torch.no_grad()\n",
        "def encode_to_latent(img_np):\n",
        "    img_t = img_to_torch(img_np)\n",
        "    return vae.encode(img_t).latent_dist.mean * SCALE_FACTOR\n",
        "\n",
        "@torch.no_grad()\n",
        "def decode_to_img(z):\n",
        "    img_t = vae.decode(z / SCALE_FACTOR).sample\n",
        "    return torch_to_img(img_t)\n",
        "\n",
        "@torch.no_grad()\n",
        "def classify_latent(z):\n",
        "    return pipeline(z).cpu().item()\n",
        "\n",
        "# Helpers do XAI (potrzebuje 224×224)\n",
        "def img_for_classifier(img_np_768):\n",
        "    \"\"\"Resize obraz 768 → 224 dla klasyfikatora.\"\"\"\n",
        "    img_pil = Image.fromarray(img_np_768.astype(np.uint8))\n",
        "    img_pil = img_pil.resize((CLF_RES, CLF_RES), Image.LANCZOS)\n",
        "    return np.array(img_pil, dtype=np.float32)\n",
        "\n",
        "def predict_tf(img_clf):\n",
        "    return model.predict(img_clf[np.newaxis], verbose=0)[0][0]\n",
        "\n",
        "def overlay_heatmap(img_array, heatmap, colormap='jet', alpha=0.5):\n",
        "    cmap = cm.get_cmap(colormap)\n",
        "    colored = cmap(heatmap)[:, :, :3]\n",
        "    img_norm = img_array / 255.0\n",
        "    return np.clip((1 - alpha) * img_norm + alpha * colored, 0, 1)\n",
        "\n",
        "print(\"✅ Helpers gotowe\")\n"
      ]
    },
