        "GD_LR = 0.05              # learning rate dla optymalizacji latentu\n",
        "GD_LAMBDA_REG = 0.0001    # regularyzacja w latencie (było 0.001 — 10× luźniej)\n",
        "TARGET_PROB_REAL = 0.005  # early stopping (było 0.05 — 10× niżej)\n",
        "\n",
        "\n",
        "# Kluczowe zmiany vs domyślnymi:\n",
        "#   GD_LAMBDA_REG: 0.001 → 0.0001 (mniejsza kotwica do z_0 → więcej swobody)\n",
        "#   TARGET_PROB_REAL: 0.05 → 0.005 (głębsze przepchnięcie do Real)\n",
        "#   N_GD_STEPS: 100 → 200 (więcej szans dla trudnych obrazów)\n",
        "#\n",
        "# Każdy obraz dostaje diagnozę konwergencji w metadata.json:\n",
        "#   - 'early_convergence': skończył <20 kroków, prob_AI bardzo niski — kotwica za mocna\n",
        "#   - 'no_convergence':    wykorzystał wszystkie kroki, prob_AI nadal wysoki — trudny obraz\n",
        "#   - 'normal':            standardowa konwergencja w środku przedziału\n",
        "\n",
        "# SD-VAE\n",
