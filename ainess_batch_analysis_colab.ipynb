        "ONNX_CLASSIFIER_PATH = DRIVE_ROOT / \"ainess_models\" / \"classifier.onnx\"\n",
        "\n",
        "# Parametry generacji — TRYB MAKSYMALNEJ ZMIANY\n",
        "EDIT_RES = 768            # rozdzielczość edycji (SD-VAE)\n",
        "CLF_RES = 224             # rozdzielczość klasyfikatora\n",
        "N_ALPHAS = 10             # liczba punktów interpolacji\n",
