      "source": [
        "## 2. Załaduj klasyfikator TensorFlow + zbuduj flat_model do XAI\n",
        "\n",
        "Logika z notebooka debugowania — rozpłaszczenie EfficientNetB0 zagnieżdżonego jako submodel, żeby tf-keras-vis mógł poprawnie liczyć gradienty.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 6,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "nuG5GdfNzs1A",
        "outputId": "08b82c0f-ef4d-4e3c-f94f-e6837d8b59c0"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Ładuję klasyfikator TensorFlow...\n",
            "  ✅ Załadowany (4,377,764 params)\n"
          ]
        }
      ],
      "source": [
        "print(\"Ładuję klasyfikator TensorFlow...\")\n",
        "model = tf.keras.models.load_model(str(TF_CLASSIFIER_PATH))\n",
        "model.trainable = False\n",
        "print(f\"  ✅ Załadowany ({model.count_params():,} params)\")\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 7,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "oI7hlvQCzs1A",
        "outputId": "d970f370-66fd-4bd0-e1c7-7b900ffdb2c0"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Buduję flat_model dla XAI...\n",
            "  Backbone: efficientnetb0 (238 warstw)\n",
            "  Wagi dopasowane: 131/131\n",
            "  ⚠ flat_model z umiarkowaną różnicą (diff=6.21e-02)\n",
            "     Powód: prawdopodobnie różnica wersji TF/Keras między treningiem a Colab\n",
            "     XAI nadal informacyjne — pokazuje *wzorce* uwagi, mogą być nieco inne magnitudy\n",
            "     Dla analizy ilościowej rozważ użycie oryginalnego TF prob (zawsze z model.predict)\n",
            "  Penultimate layer: top_conv\n"
          ]
        }
      ],
      "source": [
        "# Budowa flat_model (logika z notebooka debugowania)\n",
        "print(\"Buduję flat_model dla XAI...\")\n",
        "\n",
        "# 1. Znajdź submodel backbone\n",
        "backbone_orig = None\n",
        "for layer in model.layers:\n",
        "    if hasattr(layer, 'layers') and len(layer.layers) > 10:\n",
        "        backbone_orig = layer\n",
        "        break\n",
        "if backbone_orig is None:\n",
        "    raise RuntimeError(\"Nie znaleziono submodelu backbone w 'model'.\")\n",
        "print(f\"  Backbone: {backbone_orig.name} ({len(backbone_orig.layers)} warstw)\")\n",
        "\n",
        "# 2. Zbierz warstwy head (po backbone)\n",
        "head_layers = []\n",
        "found_backbone = False\n",
        "for layer in model.layers:\n",
        "    if layer.name == backbone_orig.name:\n",
        "        found_backbone = True\n",
        "        continue\n",
        "    if found_backbone and not isinstance(layer, tf.keras.layers.InputLayer):\n",
        "        head_layers.append(layer)\n",
        "\n",
        "# 3. Zbuduj płaski backbone (rozwija submodel)\n",
        "flat_input = tf.keras.Input(shape=(CLF_RES, CLF_RES, 3), name='flat_input')\n",
        "flat_backbone = tf.keras.applications.EfficientNetB0(\n",
        "    weights=None, include_top=False, input_tensor=flat_input\n",
        ")\n",
        "\n",
        "# 4. Kopiowanie wag layer-by-layer po nazwie (robust dla różnych wersji TF)\n",
        "#\n",
        "# Bulk set_weights() zawodzi, gdy wersja TF dodaje/usuwa preprocessing warstwy\n",
        "# w EfficientNetB0 (np. Rescaling/Normalization). Match po nazwie omija ten problem.\n",
        "orig_weights_by_name = {l.name: l.get_weights() for l in backbone_orig.layers if l.weights}\n",
        "\n",
        "matched = 0\n",
        "shape_mismatch = []\n",
        "unmatched = []\n",
        "total_with_weights = sum(1 for l in flat_backbone.layers if l.weights)\n",
        "\n",
        "for layer in flat_backbone.layers:\n",
        "    if not layer.weights:\n",
        "        continue\n",
        "    if layer.name in orig_weights_by_name:\n",
        "        try:\n",
        "            layer.set_weights(orig_weights_by_name[layer.name])\n",
        "            matched += 1\n",
        "        except ValueError as e:\n",
        "            shape_mismatch.append((layer.name, str(e)[:60]))\n",
        "    else:\n",
        "        unmatched.append(layer.name)\n",
        "\n",
        "print(f\"  Wagi dopasowane: {matched}/{total_with_weights}\")\n",
        "if shape_mismatch:\n",
        "    print(f\"  ⚠ Niezgodne kształty: {len(shape_mismatch)}\")\n",
        "    for name, err in shape_mismatch[:3]:\n",
        "        print(f\"     {name}: {err}\")\n",
        "if unmatched:\n",
        "    print(f\"  ⚠ Brak dopasowania nazwy: {len(unmatched)} (pierwsze 3: {unmatched[:3]})\")\n",
        "\n",
        "# 5. Dopnij head\n",
        "x = flat_backbone.output\n",
        "for layer in head_layers:\n",
        "    x = layer(x)\n",
        "flat_model = tf.keras.Model(flat_input, x, name='flat_model')\n",
        "\n",
        "# 6. Weryfikacja zgodności predykcji (soft check, nie hard assertion)\n",
        "test_in = np.random.uniform(0, 255, (1, CLF_RES, CLF_RES, 3)).astype(np.float32)\n",
        "p_orig = model(test_in, training=False).numpy().flatten()\n",
        "p_flat = flat_model(test_in, training=False).numpy().flatten()\n",
        "diff = np.abs(p_orig - p_flat).max()\n",
        "\n",
        "if diff < 1e-4:\n",
        "    print(f\"  ✅ flat_model w pełni zgodny (diff={diff:.2e})\")\n",
        "elif diff < 1e-2:\n",
        "    print(f\"  ✅ flat_model akceptowalnie zgodny (diff={diff:.2e})\")\n",
        "    print(f\"     XAI wyniki będą bardzo bliskie oryginalnego modelu\")\n",
        "elif diff < 0.15:\n",
        "    print(f\"  ⚠ flat_model z umiarkowaną różnicą (diff={diff:.2e})\")\n",
        "    print(f\"     Powód: prawdopodobnie różnica wersji TF/Keras między treningiem a Colab\")\n",
        "    print(f\"     XAI nadal informacyjne — pokazuje *wzorce* uwagi, mogą być nieco inne magnitudy\")\n",
        "    print(f\"     Dla analizy ilościowej rozważ użycie oryginalnego TF prob (zawsze z model.predict)\")\n",
        "else:\n",
        "    print(f\"  ⚠⚠ DUŻA NIEZGODNOŚĆ (diff={diff:.2e})\")\n",
        "    print(f\"     Sprawdź czy używasz tej samej architektury klasyfikatora co przy treningu\")\n",
        "    print(f\"     Możliwe przyczyny: zmiana TF/Keras, zmodyfikowany backbone, inny preprocessing\")\n",
        "    print(f\"     XAI będzie produkować mapy, ale ostrożnie z interpretacją\")\n",
        "\n",
        "# 7. Znajdź ostatnią Conv2D dla Grad-CAM\n",
        "last_conv = [l for l in flat_model.layers if isinstance(l, tf.keras.layers.Conv2D)][-1]\n",
        "PENULTIMATE_LAYER_NAME = last_conv.name\n",
        "print(f\"  Penultimate layer: {PENULTIMATE_LAYER_NAME}\")\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 8,
      "metadata": {
